{
    "name": "clean-react",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js",
            "require": "./dist/react/index.cjs"
        },
        "./services": {
            "types": "./dist/services/index.d.ts",
            "import": "./dist/services/index.js",
            "require": "./dist/services/index.cjs"
        }
    },
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsup index.ts react/index.ts services/index.ts --format esm,cjs --dts --out-dir dist --clean",
        "dev": "tsup index.ts react/index.ts services/index.ts --format esm,cjs --dts --out-dir dist --watch"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "rimraf": "^6.0.0"
    }
}
